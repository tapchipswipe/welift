# Required for live Retell + SMS notify
RETELL_API_KEY=key_xxxxxxxx
ONCALL_PHONE=+19415551234
DEFAULT_COMMUNITY=Pilot HOA

# false = local curl / first Retell wiring; true once API key matches Retell
VERIFY_RETELL_SIGNATURES=false

# Optional — without Twilio, OPEN/ESCALATE texts print to server logs
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Pilot: ignore valid_from/valid_until on guest entries
IGNORE_VALIDITY_WINDOW=false

# Serverless / no disk writes
SERVERLESS=false

# Paths (defaults are fine)
# GUEST_LIST_PATH=../data/guest-list.json
# EVENTS_PATH=../data/events.jsonl
# GUEST_LIST_JSON={"community_name":"Pilot HOA","entries":[]}
