# Autonomous gate + Access Desk
RETELL_API_KEY=key_xxxxxxxx
DEFAULT_COMMUNITY=The Inlets

AUTONOMOUS=true
HUMAN_SMS_FALLBACK=false

# true for sales demos / cell tests before myQ Partner API
SIMULATE_MYQ_OPEN=true

VERIFY_RETELL_SIGNATURES=false

# Twilio — required for real SMS in a sales meeting
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# SMS_LOG_ONLY=true

# Optional paths
# CREDENTIALS_PATH=../data/credentials.json
# VENDORS_PATH=../data/vendors.seed.json

# Phase 2 myQ Partner API (gate metal)
MYQ_API_BASE=
MYQ_API_KEY=
MYQ_FACILITY_ID=
MYQ_ENTRANCE_ID=

IGNORE_VALIDITY_WINDOW=false
SERVERLESS=false
