# Autonomous overnight gate attendant
RETELL_API_KEY=key_xxxxxxxx
DEFAULT_COMMUNITY=The Inlets

# Product defaults — AI verify + myQ unlock, no human awake
AUTONOMOUS=true
HUMAN_SMS_FALLBACK=false

# true only for cell demos before myQ Partner API credentials exist
SIMULATE_MYQ_OPEN=false

# false = local curl / first Retell wiring; true in prod
VERIFY_RETELL_SIGNATURES=false

# Required for real autonomous opens (Partner API)
MYQ_API_BASE=
MYQ_API_KEY=
MYQ_FACILITY_ID=
MYQ_ENTRANCE_ID=
# MYQ_UNLOCK_PATH=/v1/facilities/{facility_id}/entrances/{entrance_id}/unlock

# Guest list: file path or inline JSON for serverless
# GUEST_LIST_PATH=../data/guest-list.json
# GUEST_LIST_JSON=
IGNORE_VALIDITY_WINDOW=false
SERVERLESS=false

# Deprecated — overnight SMS wake (keep off)
# ONCALL_PHONE=+19415551234
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
