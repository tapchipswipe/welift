# Required for live Retell + SMS notify
RETELL_API_KEY=key_xxxxxxxx
ONCALL_PHONE=+19415551234
DEFAULT_COMMUNITY=The Inlets

# false = local curl / first Retell wiring; true once API key matches Retell
VERIFY_RETELL_SIGNATURES=false

# Optional — without Twilio, OPEN/ESCALATE texts print to server logs
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Pilot: ignore valid_from/valid_until on guest entries
IGNORE_VALIDITY_WINDOW=false

# Serverless / no disk writes (set true on Vercel / Fly / Railway if FS is ephemeral)
SERVERLESS=false

# Phase 2 — myQ Partner API (leave blank until credentials arrive; SMS remains fallback)
# MYQ_API_BASE=https://api.example.myq.com
# MYQ_API_KEY=
# MYQ_FACILITY_ID=
# MYQ_ENTRANCE_ID=
# MYQ_UNLOCK_PATH=/v1/facilities/{facility_id}/entrances/{entrance_id}/unlock

# Paths (defaults are fine)
# GUEST_LIST_PATH=../data/guest-list.json
# EVENTS_PATH=../data/events.jsonl
# GUEST_LIST_JSON={"community_name":"The Inlets","timezone":"America/New_York","entries":[]}
