# Autonomous gate + CAM Access Desk
RETELL_API_KEY=key_xxxxxxxx
# E.164 DID assigned to the We Lift Retell agent (shown on /gate)
RETELL_DID=
DEFAULT_COMMUNITY=The Inlets

AUTONOMOUS=true
HUMAN_SMS_FALLBACK=false

# true until myQ Partner API unlock works
SIMULATE_MYQ_OPEN=true

VERIFY_RETELL_SIGNATURES=false

# Twilio — SMS delivery of vendor gate codes
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# SMS_LOG_ONLY=true

# Optional paths (defaults under ../data/)
# CREDENTIALS_PATH=../data/credentials.json
# VENDORS_PATH=../data/vendors.json
# VENDORS_SEED_PATH=../data/vendors.seed.json

# myQ Partner API (gate metal)
MYQ_API_BASE=
MYQ_API_KEY=
MYQ_FACILITY_ID=
MYQ_ENTRANCE_ID=

IGNORE_VALIDITY_WINDOW=false
SERVERLESS=false
